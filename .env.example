CLOUDFLARE_ACCOUNT_ID=          # Cloudflare account ID (Workers dashboard URL or `wrangler whoami`)
CLOUDFLARE_API_TOKEN=           # Cloudflare API token with Workers Scripts Edit and D1 Edit

FEE_PAYER_PRIVATE_KEY_MAINNET=  # Mainnet fee payer private key (`cast wallet new`)
FEE_PAYER_PRIVATE_KEY_TESTNET=  # Moderato/localnet fee payer private key (`cast wallet new`)
RPC_URL_MAINNET=                # Mainnet RPC URL
RPC_URL_TESTNET=                # Moderato/testnet RPC URL; tests override this for localnet
SECRET_KEY=                     # Base64 secret for app encryption/signing (`openssl rand -base64 32`)
SLACK_API_URL=                  # `pnpm dev` defaults to https://slack.emulate.localhost/api unless EMULATE_SLACK=0 is set.
SLACK_APP_ID=                   # Printed by `pnpm slack:app create`
SLACK_CLIENT_ID=                # Printed by `pnpm slack:app create`
SLACK_CLIENT_SECRET=            # Printed by `pnpm slack:app create`
SLACK_SIGNING_SECRET=           # Printed by `pnpm slack:app create`
                                
SLACK_CONFIG_ACCESS_TOKEN=      # Slack app configuration token for `pnpm slack:app` commands
