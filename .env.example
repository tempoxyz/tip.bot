CLOUDFLARE_ACCOUNT_ID=          # Cloudflare account ID (Workers dashboard URL or `wrangler whoami`)
CLOUDFLARE_API_TOKEN=           # Cloudflare API token with Workers Scripts Edit and D1 Edit

FEE_PAYER_PRIVATE_KEY_MAINNET=  # Mainnet fee payer private key (`cast wallet new`)
FEE_PAYER_PRIVATE_KEY_TESTNET=  # Moderato/localnet fee payer private key (`cast wallet new`)
RPC_URL_MAINNET=                # Mainnet RPC URL
RPC_URL_TESTNET=                # Moderato/testnet RPC URL; tests override this for localnet
SECRET_KEY=                     # Base64 secret for app encryption/signing (`openssl rand -base64 32`)
SLACK_API_URL=                  # `pnpm dev` defaults to https://slack.emulate.localhost/api unless EMULATE_SLACK=0 is set.
SLACK_APP_ID=                   # Printed by `pnpm slack:app create`
SLACK_CLIENT_ID=                # Printed by `pnpm slack:app create`
SLACK_CLIENT_SECRET=            # Printed by `pnpm slack:app create`
SLACK_SIGNING_SECRET=           # Printed by `pnpm slack:app create`
TELEGRAM_API_URL=               # Defaults to https://api.telegram.org
TELEGRAM_BOT_TOKEN=             # Telegram bot token from BotFather
TELEGRAM_BOT_USERNAME=tipbot    # Telegram bot username without @
TELEGRAM_WEBHOOK_SECRET_TOKEN=  # Secret token passed to Telegram setWebhook
TWITTER_ACCESS_TOKEN=           # Twitter/X OAuth 1.0a access token for posting replies
TWITTER_ACCESS_TOKEN_SECRET=    # Twitter/X OAuth 1.0a access token secret for posting replies
TWITTER_API_URL=                # Defaults to https://api.twitter.com
TWITTER_BEARER_TOKEN=           # Twitter/X bearer token for reading tweets/users/search
TWITTER_BOT_HANDLE=tipbotgg     # Twitter/X bot handle without @
TWITTER_CONSUMER_KEY=           # Twitter/X app consumer key for webhooks and posting replies
TWITTER_CONSUMER_SECRET=        # Twitter/X app consumer secret for CRC checks and posting replies
TWITTER_OAUTH_CLIENT_ID=        # Twitter/X OAuth 2.0 client ID for account verification
TWITTER_OAUTH_CLIENT_SECRET=    # Twitter/X OAuth 2.0 client secret for account verification
                                
SLACK_CONFIG_ACCESS_TOKEN=      # Slack app configuration token for `pnpm slack:app` commands
