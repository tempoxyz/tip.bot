CLOUDFLARE_ACCOUNT_ID=                               # Cloudflare account ID (Workers dashboard URL or `wrangler whoami`)
CLOUDFLARE_API_TOKEN=                                # Cloudflare API token with Workers Scripts Edit and D1 Edit
ACCESS_KEY_ENCRYPTION_SECRET=                        # Secret for encrypting Tempo access keys and Slack bot tokens
FEE_PAYER_PRIVATE_KEY=0x                             # Tempo fee payer private key (0x-prefixed)
SLACK_APP_BASE_URL=https://your-node.tailnet.ts.net  # Public Slack callback origin (local Funnel URL or https://tip.bot)
SLACK_CLIENT_ID=                                     # Slack app client ID (Basic Information)
SLACK_CLIENT_SECRET=                                 # Slack app client secret (Basic Information)
SLACK_SIGNING_SECRET=                                # Slack app signing secret (Basic Information)
TEMPO_CHAIN=testnet                                  # Tempo chain (`testnet` or `mainnet`)

SLACK_CONFIG_TOKEN=
