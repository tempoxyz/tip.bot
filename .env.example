CLOUDFLARE_ACCOUNT_ID=         # Cloudflare account ID (Workers dashboard URL or `wrangler whoami`)
CLOUDFLARE_API_TOKEN=          # Cloudflare API token with Workers Scripts Edit and D1 Edit

SECRET_KEY=                    # Base64 secret for app encryption/signing (`openssl rand -base64 32`)
SLACK_API_URL=https://slack.com/api/
SLACK_CLIENT_ID=               # Printed by `pnpm slack:app:create`
SLACK_CLIENT_SECRET=           # Printed by `pnpm slack:app:create`
SLACK_SIGNING_SECRET=          # Printed by `pnpm slack:app:create`

SLACK_CONFIG_TOKEN=            # Slack app configuration token for `pnpm slack:app:*` scripts
