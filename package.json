{
  "name": "tipbot",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#db/*": "./db/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "check:types": "tsgo -b",
    "db:codegen": "node --experimental-strip-types db/codegen.ts",
    "db:execute": "wrangler d1 execute tipbot --local",
    "db:migrate": "wrangler d1 migrations apply tipbot --local",
    "deps": "pnpx taze -r",
    "deps:ci": "pnpx actions-up --dir .github",
    "dev": "PORTLESS_FUNNEL=1 PORTLESS_PORT=443 PORTLESS_HTTPS=1 portless run vp dev",
    "dev:app": "vp dev",
    "gen:types": "cp -n .env.example .env 2>/dev/null; wrangler types src/worker-configuration.d.ts",
    "prepare": "vp config && pnpm gen:types",
    "preview": "vp build && vp preview",
    "slack:app": "node --experimental-strip-types scripts/slack.ts",
    "test": "vp test",
    "test:e2e": "playwright test --config test/e2e.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@chat-adapter/slack": "4.27.0",
    "@hono/zod-validator": "^0.8.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.64",
    "@tanstack/router-plugin": "1.167.34",
    "chat": "4.27.0",
    "hono": "4.12.17",
    "kysely": "0.28.17",
    "nanoid": "^5.1.11",
    "ox": "0.14.20",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.36.3",
    "@cloudflare/vitest-pool-workers": "0.16.3",
    "@iconify/json": "2.2.467",
    "@playwright/test": "1.59.1",
    "@slack/web-api": "7.15.2",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/devtools-vite": "0.6.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260505.1",
    "@vitejs/plugin-react": "6.0.1",
    "better-sqlite3": "12.9.0",
    "emulate": "0.5.0",
    "msw": "2.13.6",
    "portless": "0.12.0",
    "tailwindcss": "4.2.4",
    "tiny-jsonc": "1.0.2",
    "typescript": "6.0.3",
    "unplugin-auto-import": "21.0.0",
    "unplugin-icons": "23.0.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "4.90.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.5.1",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.0.7"
}
