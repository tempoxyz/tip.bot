{
  "display_information": {
    "name": "tip.bot",
    "description": "Slack-native stablecoin micropayments",
    "background_color": "#111111"
  },
  "features": {
    "bot_user": {
      "display_name": "tip.bot",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/tip",
        "url": "https://g12wr7p453.tail388b2e.ts.net/api/slack/commands",
        "description": "Tip teammates",
        "usage_hint": "connect | @account | config",
        "should_escape": true
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "commands",
        "groups:history",
        "reactions:read",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://g12wr7p453.tail388b2e.ts.net/api/slack/events",
      "bot_events": ["app_mention", "reaction_added"]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
